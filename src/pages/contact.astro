---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import PartnerBanner from "../components/PartnerBanner.astro";

// Contact Page Hero Section
---

<Layout
  title="Contact the Performance Team | Should I Race?"
  description="Have questions about weather data or track coverage? Get in touch with our team for support, feedback, and technical inquiries."
>
  <Navbar />

  <main>
    <!-- Contact Hero Section -->
    <section
      class="relative min-h-[90vh] flex items-center justify-center overflow-hidden pt-24 pb-16"
    >
      <!-- Background Elements -->
      <div class="absolute inset-0 z-0">
        <!-- Deep Black Overlay with Glassmorphism -->
        <div
          class="absolute inset-0 bg-gradient-to-br from-deepdark 50% via-deepdark/90 80% to-deepdark/40 z-10 backdrop-blur-[2px]"
        >
        </div>

        <!-- Track Image Background -->
        <img
          src="/images/tracks/Loughborough Athletics Track.webp"
          alt="Athletics Track Background"
          class="w-full h-full object-cover opacity-40 mix-blend-luminosity grayscale scale-105"
        />

        <!-- Animated Cyan Blur Glows -->
        <div
          class="absolute -top-1/4 -right-1/4 w-[500px] h-[500px] bg-brightcyan/10 blur-[140px] rounded-full z-0 animate-pulse"
          style="animation-duration: 8s;"
        >
        </div>
        <div
          class="absolute -bottom-1/4 -left-1/4 w-[400px] h-[400px] bg-brightcyan/5 blur-[120px] rounded-full z-0 animate-pulse"
          style="animation-duration: 12s;"
        >
        </div>
      </div>

      <!-- Hero Content Container -->
      <div class="container relative z-20 mx-auto px-6 max-w-6xl">
        <div class="flex flex-col items-center text-center">
          <!-- Mission Tag -->
          <span
            class="inline-block py-2 px-6 rounded-full bg-brightcyan/10 border border-brightcyan/30 text-brightcyan text-[11px] font-black tracking-[0.3em] uppercase mb-10 animate-fade-in shadow-[0_0_25px_rgba(34,227,213,0.15)] backdrop-blur-md"
          >
            Get in touch
          </span>

          <!-- Main Bold Heading -->
          <h1
            class="text-4xl md:text-5xl lg:text-6xl font-black text-white mb-8 uppercase tracking-tighter leading-[0.85] animate-fade-in"
            style="animation-delay: 0.1s;"
          >
            Contact <span
              class="bg-gradient-to-br from-brightcyan via-cyan-400 to-cyan-600 bg-clip-text text-transparent drop-shadow-[0_0_30px_rgba(34,227,213,0.4)]"
              >Should I Race?</span
            >
          </h1>

          <!-- Modern Subheading with improved line-height -->
          <p
            class="text-xl md:text-2xl lg:text-3xl text-slate-400 max-w-4xl mx-auto mb-14 leading-relaxed font-semibold animate-fade-in text-balance"
            style="animation-delay: 0.2s;"
          >
            Have a question, feedback, or a track to add? We'd love to hear from
            you.
          </p>

          <!-- Interaction/CTA Area -->
          <div
            class="flex flex-col sm:flex-row gap-5 justify-center mt-10 animate-fade-in"
            style="animation-delay: 0.3s;"
          >
            <a
              href="mailto:info@shouldirace.com"
              class="bg-brightcyan text-deepdark px-8 py-4 rounded-full font-black text-sm md:text-base border border-transparent transition-all duration-300 hover:scale-[1.03] uppercase tracking-widest shadow-[0_0_20px_rgba(34,227,213,0.3)]"
              >Send an Email</a
            >
            <a
              href="/"
              class="bg-white/5 border border-white/10 text-white px-8 py-4 rounded-full font-bold text-sm md:text-base transition-colors hover:bg-white/10 hover:border-white/20 uppercase tracking-widest backdrop-blur-md"
              >Back to Home</a
            >
          </div>
        </div>
      </div>
    </section>

    <!-- Contact Form & Info Section -->
    <section
      class="py-24 relative overflow-hidden bg-deepdark/50"
      id="contact-form"
    >
      <div class="container mx-auto px-6 max-w-6xl">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
          <!-- Direct Contact Info -->
          <div class="space-y-8 animate-fade-in" style="animation-delay: 0.2s;">
            <div class="space-y-4">
              <span
                class="inline-block py-1.5 px-4 rounded-full bg-brightcyan/10 border border-brightcyan/30 text-brightcyan text-[10px] font-black tracking-[0.2em] uppercase"
              >
                Direct Contact
              </span>
              <h2
                class="text-4xl md:text-5xl font-black text-white leading-tight mb-6"
              >
                Let's start a conversation.
              </h2>
              <p
                class="text-slate-400 text-lg md:text-xl leading-relaxed font-medium"
              >
                Whether you have a suggestion for a new feature, a question
                about how the wind data works, or just want to chat athletics,
                we're here for it.
              </p>
            </div>

            <div
              class="bento-card relative p-8 bg-card-bg/80 backdrop-blur-xl border-white/10 group mt-8"
            >
              <div
                class="absolute -inset-4 bg-brightcyan/20 blur-3xl rounded-full opacity-20 pointer-events-none transition-opacity group-hover:opacity-40"
              >
              </div>
              <div
                class="relative z-10 flex flex-col sm:flex-row items-start sm:items-center gap-6"
              >
                <div
                  class="w-16 h-16 bg-brightcyan/10 text-brightcyan rounded-2xl flex items-center justify-center border border-brightcyan/30 shadow-[0_0_20px_rgba(34,227,213,0.15)] group-hover:scale-110 transition-transform duration-300 flex-shrink-0"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-8 h-8"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <rect width="20" height="16" x="2" y="4" rx="2"></rect>
                    <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
                  </svg>
                </div>
                <div>
                  <h3
                    class="text-sm font-bold text-slate-400 uppercase tracking-widest mb-2"
                  >
                    Email Us Directly
                  </h3>
                  <a
                    href="mailto:info@shouldirace.com"
                    class="text-2xl md:text-3xl font-black text-white hover:text-brightcyan transition-colors break-all"
                  >
                    info@shouldirace.com
                  </a>
                </div>
              </div>
            </div>
          </div>

          <!-- Contact Form UI -->
          <div
            class="bento-card p-8 md:p-12 border-white/10 bg-gradient-to-br from-card-bg/90 to-deepdark border shadow-2xl relative animate-fade-in"
            style="animation-delay: 0.4s;"
          >
            <h3
              class="text-2xl font-black text-white mb-8 border-b border-white/5 pb-4"
            >
              Send a Message
            </h3>
            <form
              action="https://formspree.io/f/xpqojkvn"
              method="POST"
              class="space-y-6"
            >
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-3">
                  <label
                    for="name"
                    class="block text-sm font-bold text-slate-300 uppercase tracking-widest"
                    >Name</label
                  >
                  <input
                    type="text"
                    id="name"
                    name="name"
                    class="w-full bg-white/5 border border-white/10 text-white px-5 py-4 rounded-xl focus:outline-none focus:border-brightcyan focus:ring-1 focus:ring-brightcyan transition-all placeholder:text-slate-600 font-medium"
                    placeholder="Usain Bolt"
                    required
                  />
                </div>
                <div class="space-y-3">
                  <label
                    for="email"
                    class="block text-sm font-bold text-slate-300 uppercase tracking-widest"
                    >Email</label
                  >
                  <input
                    type="email"
                    id="email"
                    name="email"
                    class="w-full bg-white/5 border border-white/10 text-white px-5 py-4 rounded-xl focus:outline-none focus:border-brightcyan focus:ring-1 focus:ring-brightcyan transition-all placeholder:text-slate-600 font-medium"
                    placeholder="fastest@world.com"
                    required
                  />
                </div>
              </div>
              <div class="space-y-3">
                <label
                  for="subject"
                  class="block text-sm font-bold text-slate-300 uppercase tracking-widest"
                  >Subject</label
                >
                <input
                  type="text"
                  id="subject"
                  name="subject"
                  class="w-full bg-white/5 border border-white/10 text-white px-5 py-4 rounded-xl focus:outline-none focus:border-brightcyan focus:ring-1 focus:ring-brightcyan transition-all placeholder:text-slate-600 font-medium"
                  placeholder="Track Request: London Stadium"
                  required
                />
              </div>
              <div class="space-y-3">
                <label
                  for="message"
                  class="block text-sm font-bold text-slate-300 uppercase tracking-widest"
                  >Message</label
                >
                <textarea
                  id="message"
                  name="message"
                  rows="5"
                  class="w-full bg-white/5 border border-white/10 text-white px-5 py-4 rounded-xl focus:outline-none focus:border-brightcyan focus:ring-1 focus:ring-brightcyan transition-all placeholder:text-slate-600 font-medium resize-y leading-relaxed"
                  placeholder="Hey! I wanted to check if..."
                  required></textarea>
              </div>
              <button
                type="submit"
                class="w-full bg-brightcyan text-deepdark px-8 py-5 rounded-xl font-black text-sm md:text-base border border-transparent transition-all duration-300 hover:scale-[1.02] uppercase tracking-widest shadow-[0_0_20px_rgba(34,227,213,0.3)] mt-4"
              >
                Send Message
              </button>
            </form>
          </div>
        </div>
      </div>
    </section>

    <!-- Sponsorship Opportunities Section -->
    <section class="py-24 relative overflow-hidden">
      <div class="container mx-auto px-6 max-w-5xl">
        <div class="relative animate-fade-in" style="animation-delay: 0.6s;">
          <!-- Subtle Glow Background -->
          <div
            class="absolute -inset-4 bg-brightcyan/10 blur-3xl rounded-3xl opacity-20 pointer-events-none"
          >
          </div>

          <div
            class="bento-card flex flex-col items-center text-center p-12 md:p-16 border-white/10 bg-gradient-to-br from-brightcyan/[0.08] via-card-bg/95 to-deepdark border shadow-2xl relative overflow-hidden group"
          >
            <!-- Subtle Radial Inner Glow -->
            <div
              class="absolute inset-0 bg-[radial-gradient(circle_at_50%_0%,rgba(34,227,213,0.05),transparent_70%)] pointer-events-none"
            >
            </div>

            <!-- Decorative Icon -->
            <div
              class="mx-auto w-24 h-24 bg-brightcyan/10 rounded-3xl flex items-center justify-center text-brightcyan border border-brightcyan/20 mb-8 transform group-hover:scale-110 group-hover:rotate-6 transition-all duration-500 shadow-[0_0_30px_rgba(34,227,213,0.15)]"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-12 h-12"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
                <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
              </svg>
            </div>

            <span
              class="inline-block py-1.5 px-4 rounded-full bg-white/5 border border-white/10 text-slate-300 text-[11px] font-black tracking-[0.2em] uppercase mb-6 backdrop-blur-md"
            >
              Partner With Us
            </span>

            <h2
              class="text-4xl md:text-5xl lg:text-5xl font-black text-white mb-6 uppercase tracking-tighter"
            >
              Sponsorship Opportunities
            </h2>

            <p
              class="text-slate-400 text-lg md:text-xl max-w-3xl mx-auto mb-12 leading-relaxed font-medium"
            >
              Are you a company or training group looking to reach athletes
              across the UK? We offer premium sponsorship and featuring
              opportunities throughout the Should I Race? platform. Get your
              brand in front of thousands of competitors right when they are
              planning their race weekends.
            </p>

            <a
              href="mailto:info@shouldirace.com?subject=Sponsorship%20Inquiry"
              class="inline-flex items-center gap-3 self-center w-fit bg-brightcyan text-deepdark px-10 py-5 rounded-full font-black text-sm md:text-base border border-transparent transition-all duration-300 hover:scale-[1.03] uppercase tracking-widest shadow-[0_0_20px_rgba(34,227,213,0.3)] hover:shadow-[0_0_40px_rgba(34,227,213,0.4)] relative z-10"
            >
              Become a Sponsor
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-5 h-5 flex-shrink-0"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="3"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M5 12h14m-7-7 7 7-7 7"></path>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <PartnerBanner page="contact" />
  </main>
</Layout>
