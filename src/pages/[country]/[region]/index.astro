---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import TrackCard from '../../../components/TrackCard.astro';
import PartnerBanner from '../../../components/PartnerBanner.astro';

const { country, region } = Astro.params;
const allTracks = await getCollection('tracks');

// Filter tracks by matching country & region
const tracks = allTracks.filter(t => 
  t.data.country.toLowerCase() === country?.toLowerCase() &&
  t.data.region.toLowerCase() === region?.toLowerCase()
);

if (tracks.length === 0) {
  return Astro.redirect('/404');
}

// Extract specific children generic categories
const subRegions = [...new Set(tracks.map(t => t.data.subRegion))];
---

<Layout 
  title={`Athletics Tracks in ${region?.replace(/-/g, ' ')} | Should I Race?`} 
  description={`Explore professional athletics tracks in ${region?.replace(/-/g, ' ')}. Check real-time wind conditions and plan your training or competition with live data.`}
>
  <Navbar />
  
  <main class="container mx-auto px-4 py-12 mt-20 max-w-7xl animate-fade-in">
    <!-- Breadcrumbs -->
    <nav class="flex text-sm text-slate-400 font-medium mb-8 bg-card-bg/50 border border-white/5 w-fit px-4 py-2 rounded-lg items-center text-center">
      <a href="/" class="hover:text-brightcyan transition-colors">Home</a>
      <span class="mx-2 opacity-50">/</span>
      <a href={`/${country}`} class="hover:text-brightcyan capitalize transition-colors">{country}</a>
      <span class="mx-2 opacity-50">/</span>
      <span class="text-white capitalize font-bold">{region?.replace(/-/g, ' ')}</span>
    </nav>

    <header class="mb-12">
      <h1 class="text-5xl md:text-6xl font-black text-white mb-6 uppercase tracking-tight">Tracks in {region?.replace(/-/g, ' ')}</h1>
      
      {/* SubRegions sub-navigation - hidden if only "all" exists */}
      {subRegions.length > 0 && !(subRegions.length === 1 && subRegions[0] === 'all') && (
        <div class="mb-4">
          <h2 class="text-xs font-black tracking-widest text-slate-500 uppercase mb-4">Browse by Area</h2>
          <div class="flex flex-wrap gap-4">
            {subRegions.map(sr => (
              <a href={`/${country}/${region}/${sr}`} class="bg-deepdark border border-white/10 hover:border-brightcyan/50 text-white px-6 py-3 rounded-full font-bold transition-all hover:bg-brightcyan hover:text-deepdark capitalize shadow-md hover:shadow-[0_0_15px_rgba(34,227,213,0.3)]">
                {sr.replace(/-/g, ' ')}
              </a>
            ))}
          </div>
        </div>
      )}
    </header>

    <hr class="border-white/5 mb-10" />

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {tracks.map((track) => (
        <TrackCard 
          name={track.data.name}
          city={track.data.city}
          trackUrl={
            track.data.subRegion === "all"
              ? `/${track.data.country}/${track.data.region}/${track.data.slug}`
              : `/${track.data.country}/${track.data.region}/${track.data.subRegion}/${track.data.slug}`
          }
        />
      ))}
    </div>

    <PartnerBanner page="tracks" />
  </main>
</Layout>
