---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import WindCorrectionCalculator from "../components/WindCorrectionCalculator.astro";
import PartnerBanner from "../components/PartnerBanner.astro";

// SEO Metadata
const title = "100m Time Correction for Wind Speed Calculator | Should I Race?";
const description = "Calculate how wind speed affects your 100m sprint times. Standardize your results to 0.0, +1.0, and +2.0 wind conditions using professional athletic models.";
---

<Layout title={title} description={description}>
  <Navbar />

  <main>
    <!-- Hero Section -->
    <section class="relative min-h-[60vh] flex items-center justify-center overflow-hidden pt-32 pb-20">
      <!-- Background Elements -->
      <div class="absolute inset-0 z-0">
        <div class="absolute inset-0 bg-gradient-to-b from-deepdark/50 via-deepdark to-deepdark z-10"></div>
        <img
          src="/images/tracks/Loughborough Athletics Track.webp"
          alt="Athletics Track"
          class="w-full h-full object-cover opacity-20 grayscale mix-blend-luminosity"
        />
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-brightcyan/5 blur-[120px] rounded-full animate-pulse"></div>
      </div>

      <div class="container relative z-20 mx-auto px-6 max-w-5xl text-center">
        <span class="inline-block py-2 px-6 rounded-full bg-brightcyan/10 border border-brightcyan/30 text-brightcyan text-[11px] font-black tracking-[0.3em] uppercase mb-8 animate-fade-in shadow-[0_0_20px_rgba(34,227,213,0.1)]">
          Athletic Performance Tools
        </span>
        <h1 class="text-5xl md:text-7xl font-black text-white mb-6 uppercase tracking-tighter leading-[0.9] animate-fade-in">
          100m Time Correction <br/> 
          <span class="text-brightcyan drop-shadow-[0_0_30px_rgba(34,227,213,0.3)]">for Wind Speed</span>
        </h1>
        <p class="text-xl md:text-2xl text-slate-400 max-w-3xl mx-auto font-medium leading-relaxed animate-fade-in" style="animation-delay: 0.1s;">
          Stop wondering "what if". Convert your wind-aided or headwind results into standardized times to see your true athletic potential.
        </p>
      </div>
    </section>

    <!-- Calculator Section -->
    <section class="pb-24 relative z-20 -mt-12">
      <div class="container mx-auto px-6 max-w-4xl">
        <WindCorrectionCalculator />
      </div>
    </section>

    <!-- Educational Content Section -->
    <section class="py-24 bg-card-bg/30 border-y border-white/5 relative overflow-hidden">
      <div class="container mx-auto px-6 max-w-5xl">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
          <div class="space-y-8">
            <div>
              <h2 class="text-3xl font-black text-white uppercase tracking-tight mb-6">
                Why Standardize <span class="text-brightcyan">Your Times?</span>
              </h2>
              <p class="text-slate-400 leading-relaxed font-medium text-lg">
                In elite sprinting, a +2.0 m/s tailwind is the maximum legal limit for record purposes. But not every race happens in perfect conditions. A 10.50s run into a -1.5 headwind is often a "better" performance than a 10.45s with a +2.0 tailwind.
              </p>
            </div>
            
            <div class="grid grid-cols-1 gap-6">
              <div class="flex gap-4 group">
                <div class="w-12 h-12 rounded-2xl bg-brightcyan/10 border border-brightcyan/20 flex items-center justify-center text-brightcyan flex-shrink-0 group-hover:scale-110 transition-transform">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
                </div>
                <div>
                  <h4 class="text-white font-bold uppercase tracking-wider mb-2">Track Your Progress</h4>
                  <p class="text-slate-500 text-sm leading-relaxed">Comparing seasonal bests without accounting for wind is misleading. Standardizing to 0.0 wind gives you a clear view of your actual fitness gains.</p>
                </div>
              </div>

              <div class="flex gap-4 group">
                <div class="w-12 h-12 rounded-2xl bg-brightcyan/10 border border-brightcyan/20 flex items-center justify-center text-brightcyan flex-shrink-0 group-hover:scale-110 transition-transform">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                </div>
                <div>
                  <h4 class="text-white font-bold uppercase tracking-wider mb-2">Technical Decision Making</h4>
                  <p class="text-slate-500 text-sm leading-relaxed">Understand if your technique survived the "push" of a tailwind or the "resistance" of a headwind by seeing the impact on your raw speed.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="bento-card p-10 bg-deepdark border-white/10 shadow-2xl relative">
            <h3 class="text-xl font-bold text-white mb-6 uppercase tracking-widest">How it works</h3>
            <div class="space-y-6">
              <p class="text-slate-400 text-sm leading-relaxed">
                Our calculator uses a mathematical model derived from aerodynamic research in athletics. It factors in your total time, because <strong class="text-slate-300">slower sprinters are on the track for longer</strong>, meaning the wind has more time to affect their result.
              </p>
              <div class="p-6 rounded-2xl bg-white/[0.02] border border-white/5 italic text-slate-500 text-xs font-mono leading-loose">
                Correction ≈ Wind × (0.05 × (Time / 10))
              </div>
              <p class="text-slate-400 text-sm leading-relaxed">
                This formula ensures that a 10.0s elite runner and a 12.0s developmental runner both get accurate, standardized results proportional to their speed.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Call to Action -->
    <section class="py-24 container mx-auto px-6 text-center">
      <div class="bento-card p-12 md:p-16 bg-gradient-to-br from-brightcyan/[0.05] to-deepdark border-brightcyan/20 inline-block max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-5xl font-black text-white mb-8 uppercase tracking-tighter">
          Ready for <span class="text-brightcyan leading-none">Perfect Conditions?</span>
        </h2>
        <p class="text-slate-400 text-xl font-medium mb-10 max-w-2xl mx-auto">
          Don't leave your PB to chance. Use our live wind tracker to find tracks with the best tailwinds right now.
        </p>
        <div class="flex flex-col sm:flex-row gap-5 justify-center">
          <a href="/#explorer" class="bg-brightcyan text-deepdark px-10 py-5 rounded-full font-black text-base transition-all duration-300 hover:scale-[1.05] uppercase tracking-widest shadow-[0_0_25px_rgba(34,227,213,0.3)]">
            Explore Tracks
          </a>
          <a href="/contact" class="bg-white/5 border border-white/10 text-white px-10 py-5 rounded-full font-bold text-base transition-colors hover:bg-white/10 uppercase tracking-widest backdrop-blur-md">
            Get in touch
          </a>
        </div>
      </div>
    </section>

    <PartnerBanner page="all" />
  </main>
</Layout>

<style>
  main {
    background-color: var(--deepdark);
  }
</style>
