---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import PartnerBanner from "../components/PartnerBanner.astro";

// Partner Page Content
const pricingTiers = [
  {
    name: "Site-Wide Partner",
    monthly: "10",
    annual: "120",
    features: [
      "Logo on every single page",
      "Direct link to your website",
      "Featured listing on Partnership page",
      "Standard support",
    ],
    highlight: false,
    cta: "Inquire Now",
  },
  {
    name: "Premium Partner",
    monthly: "20",
    annual: "240",
    features: [
      "All Site-Wide benefits",
      "Custom Built Pop-up",
      "Priority Placement on Homepage",
      "Quarterly Performance Reports",
    ],
    highlight: true,
    cta: "Get Premium",
  },
];
---

<Layout 
  title="Partner with Should I Race? | Elite Sponsorship" 
  description="Connect your brand with the fastest athletes in the world. Discover advertising, sponsorship, and technical partnership opportunities."
>
  <Navbar />

  <main>
    <!-- Partner Hero Section -->
    <section
      class="relative min-h-[90vh] flex items-center justify-center overflow-hidden pt-24 pb-16"
    >
      <!-- Background Elements -->
      <div class="absolute inset-0 z-0">
        <!-- Deep Black Overlay with Glassmorphism -->
        <div
          class="absolute inset-0 bg-gradient-to-br from-deepdark 50% via-deepdark/90 80% to-deepdark/40 z-10 backdrop-blur-[2px]"
        >
        </div>

        <!-- Track Image Background -->
        <img
          src="/images/tracks/Loughborough Athletics Track.webp"
          alt="Athletics Track Background"
          class="w-full h-full object-cover opacity-40 mix-blend-luminosity grayscale scale-105"
        />

        <!-- Animated Cyan Blur Glows -->
        <div
          class="absolute -top-1/4 -right-1/4 w-[500px] h-[500px] bg-brightcyan/10 blur-[140px] rounded-full z-0 animate-pulse"
          style="animation-duration: 8s;"
        >
        </div>
        <div
          class="absolute -bottom-1/4 -left-1/4 w-[400px] h-[400px] bg-brightcyan/5 blur-[120px] rounded-full z-0 animate-pulse"
          style="animation-duration: 12s;"
        >
        </div>
      </div>

      <!-- Hero Content Container -->
      <div class="container relative z-20 mx-auto px-6 max-w-6xl">
        <div class="flex flex-col items-center text-center">
          <!-- Tag -->
          <span
            class="inline-block py-2 px-6 rounded-full bg-brightcyan/10 border border-brightcyan/30 text-brightcyan text-[11px] font-black tracking-[0.3em] uppercase mb-10 animate-fade-in shadow-[0_0_25px_rgba(34,227,213,0.15)] backdrop-blur-md"
          >
            Advertise with us
          </span>

          <!-- Main Bold Heading -->
          <h1
            class="text-4xl md:text-5xl lg:text-7xl font-black text-white mb-8 uppercase tracking-tighter leading-[0.85] animate-fade-in"
            style="animation-delay: 0.1s;"
          >
            Elevate Your Brand with <span
              class="bg-gradient-to-br from-brightcyan via-cyan-400 to-cyan-600 bg-clip-text text-transparent drop-shadow-[0_0_30px_rgba(34,227,213,0.4)]"
              >Should I Race?</span
            >
          </h1>

          <!-- Modern Subheading -->
          <p
            class="text-xl md:text-2xl lg:text-3xl text-slate-400 max-w-4xl mx-auto mb-14 leading-relaxed font-semibold animate-fade-in text-balance"
            style="animation-delay: 0.2s;"
          >
            Reach a dedicated audience of UK athletes and sprinters at the
            precise moment they plan their season. Partner with the platform
            that moves with the wind.
          </p>

          <!-- Interaction/CTA Area -->
          <div
            class="flex flex-col sm:flex-row gap-5 justify-center mt-10 animate-fade-in"
            style="animation-delay: 0.3s;"
          >
            <a
              href="mailto:info@shouldirace.com?subject=Advertising Inquiry"
              class="bg-brightcyan text-deepdark px-10 py-5 rounded-full font-black text-sm md:text-base border border-transparent transition-all duration-300 hover:scale-[1.03] uppercase tracking-widest shadow-[0_0_20px_rgba(34,227,213,0.3)]"
            >
              Get Partnership Kit
            </a>
            <a
              href="/about"
              class="bg-white/5 border border-white/10 text-white px-10 py-5 rounded-full font-bold text-sm md:text-base transition-colors hover:bg-white/10 hover:border-white/20 uppercase tracking-widest backdrop-blur-md"
            >
              Why Partner with Us?
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Pricing Section -->
    <section class="py-24 relative overflow-hidden bg-deepdark/50">
      <div class="container relative z-10 mx-auto px-6 max-w-6xl">
        <div class="text-center max-w-3xl mx-auto mb-16 animate-fade-in">
          <span
            class="inline-block py-1.5 px-4 rounded-full bg-brightcyan/10 border border-brightcyan/30 text-brightcyan text-[10px] font-black tracking-[0.2em] uppercase mb-6"
          >
            Transparent Pricing
          </span>
          <h2
            class="text-4xl md:text-5xl font-black text-white mb-6 uppercase tracking-tighter"
          >
            Choose Your <span class="text-brightcyan">Impact</span>
          </h2>
          <p class="text-slate-400 text-lg md:text-xl font-medium">
            Select the partnership tier that best aligns with your brand goals.
            High-visibility placements designed for maximum athlete engagement.
          </p>
        </div>

        <div
          class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12 max-w-5xl mx-auto"
        >
          {
            pricingTiers.map((tier, index) => (
              <div
                class={`bento-card relative flex flex-col p-8 md:p-12 transition-all duration-500 animate-fade-in ${
                  tier.highlight
                    ? "border-brightcyan/40 bg-gradient-to-br from-brightcyan/[0.07] via-card-bg to-deepdark shadow-[0_0_50px_rgba(34,227,213,0.1)]"
                    : "bg-card-bg/50 border-white/5"
                }`}
                style={`animation-delay: ${0.2 + index * 0.1}s;`}
              >
                {tier.highlight && (
                  <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-brightcyan text-deepdark text-[10px] font-black uppercase tracking-[0.2em] px-4 py-1.5 rounded-full shadow-[0_0_20px_rgba(34,227,213,0.4)]">
                    Maximum Impact
                  </div>
                )}

                <div class="mb-10">
                  <h3 class="text-2xl font-black text-white mb-4 uppercase tracking-tight">
                    {tier.name}
                  </h3>
                  <div class="flex items-baseline gap-2">
                    <span class="text-5xl font-black text-white">
                      £{tier.monthly}
                    </span>
                    <span class="text-slate-500 font-bold uppercase tracking-widest text-xs">
                      / Month
                    </span>
                  </div>
                  <p class="text-slate-400 text-sm mt-2 font-bold uppercase tracking-widest">
                    £{tier.annual} billed annually
                  </p>
                </div>

                <div class="space-y-5 mb-12 flex-grow">
                  {tier.features.map((feature) => (
                    <div class="flex items-start gap-4 group">
                      <div
                        class={`flex-shrink-0 w-6 h-6 rounded-full flex items-center justify-center border ${
                          tier.highlight
                            ? "bg-brightcyan/20 border-brightcyan/30 text-brightcyan"
                            : "bg-white/5 border-white/10 text-slate-400"
                        }`}
                      >
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          class="w-3.5 h-3.5"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="4"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        >
                          <polyline points="20 6 9 17 4 12" />
                        </svg>
                      </div>
                      <span class="text-slate-300 font-medium group-hover:text-white transition-colors">
                        {feature}
                      </span>
                    </div>
                  ))}
                </div>

                <a
                  href="mailto:info@shouldirace.com?subject=Partnership Inquiry"
                  class={`w-full py-5 rounded-2xl font-black text-center uppercase tracking-widest transition-all duration-300 hover:scale-[1.02] ${
                    tier.highlight
                      ? "bg-brightcyan text-deepdark shadow-[0_0_25px_rgba(34,227,213,0.3)]"
                      : "bg-white/5 border border-white/10 text-white hover:bg-white/10"
                  }`}
                >
                  {tier.cta}
                </a>
              </div>
            ))
          }
        </div>

        {/* Footer Contact CTA */}
        <div
          class="mt-24 text-center animate-fade-in"
          style="animation-delay: 0.5s;"
        >
          <p class="text-slate-400 font-medium mb-6">
            Looking for a custom integration or multi-season discount?
          </p>
          <a
            href="mailto:info@shouldirace.com"
            class="text-brightcyan font-black uppercase tracking-[0.2em] text-sm hover:text-white transition-colors border-b border-brightcyan/30 pb-1"
          >
            Contact our partnership team →
          </a>
        </div>
      </div>
    </section>

    <!-- Detailed Tier Descriptions Section -->
    <section class="py-28 relative overflow-hidden">
      <!-- Subtle background glow -->
      <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-brightcyan/[0.03] blur-[150px] rounded-full pointer-events-none"
      >
      </div>

      <div class="container relative z-10 mx-auto px-6 max-w-6xl">
        <!-- Section Header -->
        <div class="text-center max-w-3xl mx-auto mb-20 animate-fade-in">
          <span
            class="inline-block py-1.5 px-4 rounded-full bg-brightcyan/10 border border-brightcyan/30 text-brightcyan text-[10px] font-black tracking-[0.2em] uppercase mb-6"
          >
            What's Included
          </span>
          <h2
            class="text-4xl md:text-5xl font-black text-white mb-6 uppercase tracking-tighter"
          >
            Tier <span class="text-brightcyan">Breakdown</span>
          </h2>
          <p class="text-slate-400 text-lg md:text-xl font-medium">
            A closer look at exactly what each partnership tier delivers for
            your brand.
          </p>
        </div>

        <!-- Tier Cards -->
        <div class="flex flex-col gap-10">
          <!-- Tier 1: Site-Wide Partner -->
          <div
            class="bento-card relative p-8 md:p-12 animate-fade-in"
            style="animation-delay: 0.1s;"
          >
            <!-- Tier Number -->
            <div
              class="absolute -top-5 -left-1 w-10 h-10 bg-deepdark border border-white/10 rounded-xl flex items-center justify-center text-slate-500 font-black text-xs tracking-widest"
            >
              01
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
              <!-- Left: Name & Price -->
              <div class="lg:col-span-1 flex flex-col justify-between">
                <div>
                  <span
                    class="text-[10px] font-black tracking-[0.2em] uppercase text-slate-500 mb-3 block"
                    >Entry Tier</span
                  >
                  <h3
                    class="text-3xl font-black text-white uppercase tracking-tight mb-4"
                  >
                    Site-Wide<br />Partner
                  </h3>
                  <div class="flex items-baseline gap-2 mb-2">
                    <span class="text-4xl font-black text-white">£10</span>
                    <span
                      class="text-slate-500 font-bold uppercase tracking-widest text-xs"
                      >/ Month</span
                    >
                  </div>
                  <p
                    class="text-slate-500 text-xs font-bold uppercase tracking-widest"
                  >
                    £120 billed annually
                  </p>
                </div>
                <a
                  href="mailto:info@shouldirace.com?subject=Site-Wide Partner Inquiry"
                  class="mt-8 inline-block text-center py-4 px-8 rounded-2xl bg-white/5 border border-white/10 text-white font-black text-xs uppercase tracking-widest hover:bg-white/10 hover:border-white/20 transition-all duration-300"
                >
                  Inquire Now
                </a>
              </div>

              <!-- Right: Detail Points -->
              <div class="lg:col-span-2 space-y-8">
                <!-- Benefit 1 -->
                <div class="flex gap-5">
                  <div
                    class="flex-shrink-0 w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-slate-400"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="w-4 h-4"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <rect x="3" y="3" width="18" height="18" rx="2"
                      ></rect><path d="M3 9h18M9 21V9"></path>
                    </svg>
                  </div>
                  <div>
                    <h4
                      class="text-white font-black text-sm uppercase tracking-wider mb-1"
                    >
                      Static Presence Across the Platform
                    </h4>
                    <p
                      class="text-slate-400 font-medium leading-relaxed text-sm"
                    >
                      Your logo and a direct link to your website appear on
                      every track and location page — giving your brand
                      consistent exposure to all <strong class="text-slate-300"
                        >13,000+ seasonal visitors</strong
                      > who use the platform to plan their training.
                    </p>
                  </div>
                </div>

                <!-- Benefit 2 -->
                <div class="flex gap-5">
                  <div
                    class="flex-shrink-0 w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-slate-400"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="w-4 h-4"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M12 2L2 7l10 5 10-5-10-5z"></path><path
                        d="M2 17l10 5 10-5"></path><path d="M2 12l10 5 10-5"
                      ></path>
                    </svg>
                  </div>
                  <div>
                    <h4
                      class="text-white font-black text-sm uppercase tracking-wider mb-1"
                    >
                      Dedicated Partnership Page Listing
                    </h4>
                    <p
                      class="text-slate-400 font-medium leading-relaxed text-sm"
                    >
                      Your brand secures a dedicated slot in the "Featured
                      Partners" section of this page, complete with your logo, a
                      short brand description, and a direct link to your
                      website.
                    </p>
                  </div>
                </div>

                <!-- Benefit 3 / Value -->
                <div class="flex gap-5">
                  <div
                    class="flex-shrink-0 w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-slate-400"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="w-4 h-4"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"
                      ></polyline><polyline points="17 6 23 6 23 12"></polyline>
                    </svg>
                  </div>
                  <div>
                    <h4
                      class="text-white font-black text-sm uppercase tracking-wider mb-1"
                    >
                      Long-Term Brand Reinforcement & SEO
                    </h4>
                    <p
                      class="text-slate-400 font-medium leading-relaxed text-sm"
                    >
                      Beyond direct traffic, site-wide backlinks provide
                      compounding SEO value for your domain over time — an
                      accessible entry point that delivers meaningful,
                      measurable returns.
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Tier 2: Premium Partner -->
          <div
            class="bento-card relative p-8 md:p-12 border-brightcyan/25 bg-gradient-to-br from-brightcyan/[0.05] via-card-bg to-deepdark shadow-[0_0_60px_rgba(34,227,213,0.08)] animate-fade-in"
            style="animation-delay: 0.2s;"
          >
            <!-- Premium Badge -->
            <div
              class="absolute -top-4 left-12 bg-brightcyan text-deepdark text-[10px] font-black uppercase tracking-[0.2em] px-4 py-1.5 rounded-full shadow-[0_0_20px_rgba(34,227,213,0.4)]"
            >
              Maximum Impact
            </div>
            <!-- Tier Number -->
            <div
              class="absolute -top-5 -left-1 w-10 h-10 bg-deepdark border border-brightcyan/20 rounded-xl flex items-center justify-center text-brightcyan font-black text-xs tracking-widest"
            >
              02
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
              <!-- Left: Name & Price -->
              <div class="lg:col-span-1 flex flex-col justify-between">
                <div>
                  <span
                    class="text-[10px] font-black tracking-[0.2em] uppercase text-brightcyan/60 mb-3 block"
                    >Premium Tier</span
                  >
                  <h3
                    class="text-3xl font-black text-white uppercase tracking-tight mb-4"
                  >
                    Premium<br />Partner
                  </h3>
                  <div class="flex items-baseline gap-2 mb-2">
                    <span class="text-4xl font-black text-white">£20</span>
                    <span
                      class="text-slate-500 font-bold uppercase tracking-widest text-xs"
                      >/ Month</span
                    >
                  </div>
                  <p
                    class="text-slate-500 text-xs font-bold uppercase tracking-widest"
                  >
                    £240 billed annually
                  </p>
                </div>
                <a
                  href="mailto:info@shouldirace.com?subject=Premium Partner Inquiry"
                  class="mt-8 inline-block text-center py-4 px-8 rounded-2xl bg-brightcyan text-deepdark font-black text-xs uppercase tracking-widest shadow-[0_0_25px_rgba(34,227,213,0.3)] hover:scale-[1.02] transition-all duration-300"
                >
                  Get Premium
                </a>
              </div>

              <!-- Right: Detail Points -->
              <div class="lg:col-span-2 space-y-8">
                <!-- Benefit 1 -->
                <div class="flex gap-5">
                  <div
                    class="flex-shrink-0 w-10 h-10 rounded-xl bg-brightcyan/10 border border-brightcyan/20 flex items-center justify-center text-brightcyan"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="w-4 h-4"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"
                      ></path><polyline points="10 17 15 12 10 7"
                      ></polyline><line x1="15" y1="12" x2="3" y2="12"></line>
                    </svg>
                  </div>
                  <div>
                    <h4
                      class="text-brightcyan font-black text-sm uppercase tracking-wider mb-1"
                    >
                      Custom-Built Pop-Up Overlay
                    </h4>
                    <p
                      class="text-slate-400 font-medium leading-relaxed text-sm"
                    >
                      Includes a professionally designed overlay advertisement
                      built specifically for your campaign. Unlike standard
                      display ads, this pop-up is engineered to <strong
                        class="text-slate-300"
                        >target specific user behaviours or page categories</strong
                      > based on your brief — delivering the right message at the
                      right moment.
                    </p>
                  </div>
                </div>

                <!-- Benefit 2 -->
                <div class="flex gap-5">
                  <div
                    class="flex-shrink-0 w-10 h-10 rounded-xl bg-brightcyan/10 border border-brightcyan/20 flex items-center justify-center text-brightcyan"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="w-4 h-4"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path
                        d="M23 12a11.05 11.05 0 0 0-22 0zm-5 7a3 3 0 0 1-6 0v-7"
                      ></path>
                    </svg>
                  </div>
                  <div>
                    <h4
                      class="text-brightcyan font-black text-sm uppercase tracking-wider mb-1"
                    >
                      Full Monthly Creative Flexibility
                    </h4>
                    <p
                      class="text-slate-400 font-medium leading-relaxed text-sm"
                    >
                      You can update the creative or retarget the pop-up's
                      audience logic <strong class="text-slate-300"
                        >once per month</strong
                      > — keeping your ads perfectly aligned with your own seasonal
                      sales, product launches, or promotions without any extra cost.
                    </p>
                  </div>
                </div>

                <!-- Benefit 3 / Value -->
                <div class="flex gap-5">
                  <div
                    class="flex-shrink-0 w-10 h-10 rounded-xl bg-brightcyan/10 border border-brightcyan/20 flex items-center justify-center text-brightcyan"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="w-4 h-4"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"
                      ></path><polyline points="22 4 12 14.01 9 11.01"
                      ></polyline>
                    </svg>
                  </div>
                  <div>
                    <h4
                      class="text-brightcyan font-black text-sm uppercase tracking-wider mb-1"
                    >
                      Superior Conversion Performance
                    </h4>
                    <p
                      class="text-slate-400 font-medium leading-relaxed text-sm"
                    >
                      Custom-targeted pop-ups consistently outperform static
                      banners by delivering a <strong class="text-slate-300"
                        >specific, relevant call to action</strong
                      > to a defined segment of your audience — converting casual
                      visitors into engaged customers at a measurably higher rate.
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <PartnerBanner page="partner" heading="Featured Partners" />
  </main>
</Layout>
