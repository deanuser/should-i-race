---
/**
 * PartnerBanner — Reusable partner card strip
 */

import { getPartnersForPage, type PartnerPage } from "../data/partners";

interface Props {
  /** Which page is this banner being placed on? */
  page: PartnerPage;
  /**
   * Optional heading override.
   * Defaults to "Our Partners".
   */
  heading?: string;
  /**
   * Layout variant: 
   * 'full' (for large bottom-of-page sections) 
   * 'sidebar' (for narrow vertical columns)
   */
  variant?: "full" | "sidebar";
}

const { page, heading = "Our Partners", variant = "full" } = Astro.props;
const activePartners = getPartnersForPage(page);

const isSidebar = variant === "sidebar";
---

{
  activePartners.length > 0 && (
    <section class={`partner-banner relative overflow-hidden ${isSidebar ? "" : "py-16"}`}>
      {/* Subtle ambient glow */}
      <div class={`absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-brightcyan/[0.04] blur-[120px] rounded-full pointer-events-none ${isSidebar ? "w-[300px] h-[150px]" : "w-[600px] h-[300px]"}`} />

      <div class={`${isSidebar ? "" : "container mx-auto px-6 max-w-6xl"} relative z-10`}>
        {/* Section label */}
        <div class={`flex items-center gap-4 ${isSidebar ? "mb-6" : "mb-10 text-center"}`}>
          <span class="inline-block py-1.5 px-4 rounded-full bg-brightcyan/10 border border-brightcyan/30 text-brightcyan text-[10px] font-black tracking-[0.2em] uppercase">
            {heading}
          </span>
          <div class="flex-1 h-px bg-white/5" />
        </div>

        {/* Cards grid */}
        <div class={`grid gap-6 ${isSidebar ? "grid-cols-1" : "grid-cols-1 sm:grid-cols-2 lg:grid-cols-3"}`}>
          {activePartners.map((partner) => (
            <div class={`partner-card group bento-card flex flex-col items-start gap-5 transition-all duration-300 hover:border-brightcyan/20 hover:shadow-[0_0_30px_rgba(34,227,213,0.06)] ${isSidebar ? "p-5" : "p-6"}`}>
              {/* Tier badge */}
              <span
                class={`self-start text-[9px] font-black uppercase tracking-[0.2em] px-3 py-1 rounded-full border ${
                  partner.tier === "Premium Partner"
                    ? "bg-brightcyan/10 border-brightcyan/30 text-brightcyan"
                    : "bg-white/5 border-white/10 text-slate-400"
                }`}
              >
                {partner.tier}
              </span>

              {/* Logo */}
              <div class="w-full h-16 flex items-center">
                <img
                  src={partner.logo}
                  alt={`${partner.name} logo`}
                  class="max-h-14 max-w-[160px] object-contain opacity-80 group-hover:opacity-100 transition-opacity duration-300"
                />
              </div>

              {/* Name + description */}
              <div class="flex-1">
                <h3 class="text-white font-black text-base uppercase tracking-tight mb-2">
                  {partner.name}
                </h3>
                <p class="text-slate-400 text-sm font-medium leading-relaxed">
                  {partner.description}
                </p>
              </div>

              {/* CTA */}
              <a
                href={partner.website}
                target="_blank"
                rel="noopener noreferrer"
                class={`mt-auto w-full text-center py-3 px-6 rounded-xl font-black text-xs uppercase tracking-widest transition-all duration-300 hover:scale-[1.02] ${
                  partner.tier === "Premium Partner"
                    ? "bg-brightcyan text-deepdark shadow-[0_0_20px_rgba(34,227,213,0.25)]"
                    : "bg-white/5 border border-white/10 text-white hover:bg-white/10"
                }`}
              >
                Visit Website →
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}
