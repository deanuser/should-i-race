---
// Navbar.astro
import { getCollection } from "astro:content";

const allTracks = await getCollection("tracks");
const trackData = allTracks.map((t) => ({
  name: t.data.name,
  city: t.data.city,
  url:
    t.data.subRegion === "all"
      ? `/${t.data.country}/${t.data.region}/${t.data.slug}`
      : `/${t.data.country}/${t.data.region}/${t.data.subRegion}/${t.data.slug}`,
}));
---

<nav
  id="main-nav"
  class="fixed top-0 left-0 w-full z-50 bg-deepdark/90 backdrop-blur-md border-b border-white/5 transition-all duration-300 animate-fade-in"
>
  <div
    class="container mx-auto max-w-7xl px-4 md:px-6 h-20 flex justify-between items-center gap-4"
  >
    <!-- Logo -->
    <a
      href="/"
      class="flex items-center gap-2 hover:opacity-80 transition-opacity flex-shrink-0 z-[60]"
    >
      <img
        src="/images/logos/logo side.webp"
        alt="Should I Run Logo"
        class="h-10 md:h-12 w-auto object-contain drop-shadow-lg"
      />
    </a>

    <!-- Search Bar (desktop, hidden by default) -->
    <div
      id="nav-search-container"
      class="flex-1 max-w-lg hidden opacity-0 transition-all duration-300"
    >
      <div class="relative">
        <svg
          class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-brightcyan pointer-events-none"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2.5"
          ><circle cx="11" cy="11" r="8"></circle><line
            x1="21"
            y1="21"
            x2="16.65"
            y2="16.65"></line></svg
        >
        <input
          id="nav-search-input"
          type="text"
          placeholder="Search tracks by name or city..."
          class="w-full bg-white/5 border border-white/15 focus:border-brightcyan/60 rounded-full pl-11 pr-4 py-2.5 text-sm text-white placeholder-slate-500 outline-none transition-all duration-200"
          autocomplete="off"
        />
        <div
          id="nav-search-results"
          class="absolute top-full left-0 right-0 mt-2 bg-deepdark/95 backdrop-blur-xl border border-white/10 rounded-2xl shadow-2xl overflow-hidden hidden z-50 max-h-80 overflow-y-auto"
        >
        </div>
      </div>
    </div>

    <!-- Desktop Nav links + controls -->
    <ul class="flex items-center gap-4 md:gap-6 list-none m-0 p-0 flex-shrink-0">
      <!-- Search Toggle -->
      <li class="hidden md:flex">
        <button
          id="nav-search-toggle"
          aria-label="Search tracks"
          class="w-9 h-9 flex items-center justify-center text-slate-400 hover:text-brightcyan transition-colors rounded-full hover:bg-white/5 z-[60] relative"
        >
          <svg
            id="search-icon"
            xmlns="http://www.w3.org/2000/svg"
            class="w-5 h-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2.5"
            ><circle cx="11" cy="11" r="8"></circle><line
              x1="21"
              y1="21"
              x2="16.65"
              y2="16.65"></line></svg
          >
          <svg
            id="search-close-icon"
            xmlns="http://www.w3.org/2000/svg"
            class="w-5 h-5 hidden"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2.5"
            ><line x1="18" y1="6" x2="6" y2="18"></line><line
              x1="6"
              y1="6"
              x2="18"
              y2="18"></line></svg
          >
        </button>
      </li>

      <!-- Desktop Links (hidden on mobile) -->
      <li class="hidden md:block">
        <a
          href="/#tracks"
          class="text-slate-300 hover:text-brightcyan font-semibold text-sm transition-colors tracking-wide uppercase"
          >Tracks</a
        >
      </li>
      <li class="hidden md:block">
        <a
          href="/about"
          class="text-slate-300 hover:text-brightcyan font-semibold text-sm transition-colors tracking-wide uppercase"
          >About</a
        >
      </li>
      <li class="hidden md:block">
        <a
          href="/partner"
          class="text-slate-300 hover:text-brightcyan font-semibold text-sm transition-colors tracking-wide uppercase"
          >Partnership</a
        >
      </li>
      <li class="hidden md:block">
        <a
          href="/contact"
          class="text-slate-300 hover:text-brightcyan font-semibold text-sm transition-colors tracking-wide uppercase"
          >Contact</a
        >
      </li>
      <li class="hidden md:block">
        <a
          href="https://www.paypal.com/donate/?hosted_button_id=Q3BH2KU2Z7JPY"
          target="_blank"
          rel="noopener noreferrer"
          class="bg-brightcyan/10 text-brightcyan hover:bg-brightcyan hover:text-deepdark border border-brightcyan/40 px-6 py-2 rounded-full font-bold text-sm tracking-wide transition-all duration-300 uppercase"
          >Buy Me a Coffee ☕</a
        >
      </li>

      <!-- Hamburger (mobile only) -->
      <li class="md:hidden">
        <button
          id="mobile-menu-toggle"
          aria-label="Open menu"
          aria-expanded="false"
          class="w-11 h-11 flex flex-col justify-center items-center z-[60] relative bg-white/5 border border-white/10 rounded-full transition-all duration-300 hover:bg-white/10 group active:scale-95"
        >
          <div class="relative w-6 h-5 flex flex-col justify-center items-center">
            <span
              id="burger-line-1"
              class="block w-6 h-[2.5px] bg-white rounded-full transition-all duration-300 origin-center absolute top-[4px]"
            ></span>
            <span
              id="burger-line-2"
              class="block w-4 h-[2.5px] bg-white rounded-full transition-all duration-300 origin-center absolute bottom-[4px] self-end group-hover:w-6"
            ></span>
          </div>
        </button>
      </li>
    </ul>
  </div>
</nav>

<!-- Full-Screen Mobile Menu Overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 bg-deepdark flex flex-col pointer-events-none opacity-0"
  style="transition: opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1);"
  aria-hidden="true"
>
  <!-- Cyan glow accent -->
  <div
    class="absolute top-0 right-0 w-80 h-80 bg-brightcyan/10 blur-[120px] rounded-full pointer-events-none"
  >
  </div>
  <div
    class="absolute bottom-0 left-0 w-64 h-64 bg-brightcyan/5 blur-[100px] rounded-full pointer-events-none"
  >
  </div>

  <!-- Menu content: centred vertically -->
  <div
    class="flex-1 flex flex-col justify-center px-8 pt-24 pb-12 relative z-10"
  >
    <!-- Mobile Full-Width Search -->
    <div class="relative mb-8">
      <svg
        class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-brightcyan pointer-events-none"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2.5"
        ><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg
      >
      <input
        id="mobile-search-input"
        type="text"
        placeholder="Search tracks by name or city..."
        class="w-full bg-white/5 border border-white/15 focus:border-brightcyan/60 rounded-2xl pl-12 pr-4 py-4 text-base text-white placeholder-slate-500 outline-none transition-all duration-200"
        autocomplete="off"
      />
      <div
        id="mobile-search-results"
        class="absolute top-full left-0 right-0 mt-2 bg-deepdark/98 backdrop-blur-xl border border-white/10 rounded-2xl shadow-2xl overflow-hidden hidden z-50 max-h-80 overflow-y-auto"
      >
      </div>
    </div>

    <!-- Nav Links -->
    <nav class="flex flex-col gap-2 mb-12">
      {
        [
          { href: "/#tracks", label: "Tracks" },
          { href: "/about", label: "About" },
          { href: "/partner", label: "Partnership" },
          { href: "/contact", label: "Contact" },
        ].map((link, i) => (
          <a
            href={link.href}
            class="mobile-nav-link text-4xl font-black text-white uppercase tracking-tighter leading-none py-3 border-b border-white/5 flex items-center justify-between group"
            style={`transition-delay: ${i * 60}ms;`}
          >
            <span class="group-hover:text-brightcyan transition-colors duration-200">
              {link.label}
            </span>
            <svg
              class="w-6 h-6 text-brightcyan/40 group-hover:text-brightcyan group-hover:translate-x-1 transition-all duration-200"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <polyline points="9 18 15 12 9 6" />
            </svg>
          </a>
        ))
      }
    </nav>

    <!-- CTA Button -->
    <a
      href="https://www.paypal.com/donate/?hosted_button_id=Q3BH2KU2Z7JPY"
      target="_blank"
      rel="noopener noreferrer"
      id="mobile-cta"
      class="inline-flex items-center justify-center gap-2 bg-brightcyan text-deepdark px-8 py-4 rounded-full font-black text-base tracking-widest uppercase shadow-[0_0_30px_rgba(34,227,213,0.3)] hover:shadow-[0_0_40px_rgba(34,227,213,0.5)] transition-all duration-300 w-full text-center mb-10"
    >
      Buy Me a Coffee ☕
    </a>

    <!-- Social Links -->
    <div
      id="mobile-socials"
      class="flex items-center gap-5 opacity-0 translate-y-4"
      style="transition: opacity 0.4s ease 0.35s, transform 0.4s ease 0.35s;"
    >
      <a
        href="https://www.facebook.com/deandaviswebdesign"
        target="_blank"
        rel="noopener noreferrer"
        class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-slate-400 hover:text-brightcyan hover:border-brightcyan/40 transition-all duration-300"
      >
        <svg
          class="w-5 h-5"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          ><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"
          ></path></svg
        >
      </a>
      <a
        href="https://www.linkedin.com/in/dean-davis-9b84642b/"
        target="_blank"
        rel="noopener noreferrer"
        class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-slate-400 hover:text-brightcyan hover:border-brightcyan/40 transition-all duration-300"
      >
        <svg
          class="w-5 h-5"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          ><path
            d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
          ></path><rect x="2" y="9" width="4" height="12"></rect><circle
            cx="4"
            cy="4"
            r="2"></circle></svg
        >
      </a>
      <a
        href="https://www.instagram.com/deanandthat/"
        target="_blank"
        rel="noopener noreferrer"
        class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-slate-400 hover:text-brightcyan hover:border-brightcyan/40 transition-all duration-300"
      >
        <svg
          class="w-5 h-5"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          ><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path
            d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line
            x1="17.5"
            y1="6.5"
            x2="17.51"
            y2="6.5"></line></svg
        >
      </a>
    </div>
  </div>

  <!-- Bottom tagline -->
  <div
    id="mobile-footer-tag"
    class="relative z-10 px-8 pb-8 opacity-0"
    style="transition: opacity 0.4s ease 0.4s;"
  >
    <p class="text-slate-600 text-xs uppercase tracking-widest font-bold">
      Should I Race? · Real-time wind intel for athletes
    </p>
  </div>
</div>

<style>
  /* Burger animation states */
  .burger-open #burger-line-1 {
    transform: translateY(4.5px) rotate(45deg);
    background-color: #22e3d5;
  }
  .burger-open #burger-line-2 {
    width: 1.5rem; /* w-6 */
    transform: translateY(-4.5px) rotate(-45deg);
    background-color: #22e3d5;
  }

  /* Mobile nav link entrance */
  .mobile-nav-link {
    opacity: 0;
    transform: translateX(-24px);
    transition:
      opacity 0.35s ease,
      transform 0.35s ease,
      color 0.2s ease;
  }

  .menu-open .mobile-nav-link {
    opacity: 1;
    transform: translateX(0);
  }

  .menu-open #mobile-socials,
  .menu-open #mobile-footer-tag,
  .menu-open #mobile-cta {
    opacity: 1 !important;
    transform: translateY(0) !important;
  }

  #mobile-cta {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.4s ease 0.28s, transform 0.4s ease 0.28s;
  }
</style>

<script define:vars={{ trackData }}>
  // ── Mobile Menu ──────────────────────────────────────────────
  const mobileToggle = document.getElementById("mobile-menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");
  const burgerBtn = document.getElementById("mobile-menu-toggle");
  let menuOpen = false;

  function openMobileMenu() {
    menuOpen = true;
    mobileMenu.classList.remove("pointer-events-none");
    mobileMenu.style.opacity = "1";
    mobileMenu.setAttribute("aria-hidden", "false");
    mobileMenu.classList.add("menu-open");
    burgerBtn.classList.add("burger-open");
    burgerBtn.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
  }

  function closeMobileMenu() {
    menuOpen = false;
    mobileMenu.style.opacity = "0";
    mobileMenu.classList.remove("menu-open");
    burgerBtn.classList.remove("burger-open");
    burgerBtn.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
    setTimeout(() => {
      mobileMenu.classList.add("pointer-events-none");
      mobileMenu.setAttribute("aria-hidden", "true");
    }, 400);
  }

  mobileToggle.addEventListener("click", () => {
    menuOpen ? closeMobileMenu() : openMobileMenu();
  });

  // Close when a mobile nav link is clicked
  document.querySelectorAll(".mobile-nav-link").forEach((link) => {
    link.addEventListener("click", closeMobileMenu);
  });

  // Close on Escape
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && menuOpen) closeMobileMenu();
  });

  // ── Desktop Search ───────────────────────────────────────────
  const searchToggle = document.getElementById("nav-search-toggle");
  const searchContainer = document.getElementById("nav-search-container");
  const searchInput = document.getElementById("nav-search-input");
  const searchResults = document.getElementById("nav-search-results");
  const searchIcon = document.getElementById("search-icon");
  const searchCloseIcon = document.getElementById("search-close-icon");

  let searchOpen = false;

  function openSearch() {
    searchOpen = true;
    searchContainer.classList.remove("hidden");
    requestAnimationFrame(() => {
      searchContainer.classList.remove("opacity-0");
      searchContainer.classList.add("opacity-100");
    });
    searchIcon.classList.add("hidden");
    searchCloseIcon.classList.remove("hidden");
    setTimeout(() => searchInput.focus(), 50);
  }

  function closeSearch() {
    searchOpen = false;
    searchContainer.classList.add("opacity-0");
    searchContainer.classList.remove("opacity-100");
    setTimeout(() => searchContainer.classList.add("hidden"), 300);
    searchIcon.classList.remove("hidden");
    searchCloseIcon.classList.add("hidden");
    searchInput.value = "";
    searchResults.classList.add("hidden");
    searchResults.innerHTML = "";
  }

  searchToggle.addEventListener("click", () => {
    searchOpen ? closeSearch() : openSearch();
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && searchOpen) closeSearch();
  });

  document.addEventListener("click", (e) => {
    if (
      searchOpen &&
      !searchContainer.contains(e.target) &&
      !searchToggle.contains(e.target)
    ) {
      closeSearch();
    }
  });

  searchInput.addEventListener("input", () => {
    const query = searchInput.value.trim().toLowerCase();
    searchResults.innerHTML = "";

    if (query.length < 2) {
      searchResults.classList.add("hidden");
      return;
    }

    const matches = trackData.filter(
      (t) =>
        t.name.toLowerCase().includes(query) ||
        t.city.toLowerCase().includes(query)
    );

    if (matches.length === 0) {
      searchResults.innerHTML = `<div class="px-5 py-4 text-slate-400 text-sm">No tracks found for "<span class="text-white font-bold">${searchInput.value}</span>"</div>`;
      searchResults.classList.remove("hidden");
      return;
    }

    matches.slice(0, 8).forEach((track) => {
      const item = document.createElement("a");
      item.href = track.url;
      item.className =
        "flex items-center gap-3 px-5 py-3.5 hover:bg-brightcyan/10 transition-colors border-b border-white/5 last:border-0 group";

      const highlighted = (str) =>
        str.replace(
          new RegExp(`(${query})`, "gi"),
          '<mark class="bg-brightcyan/30 text-brightcyan rounded px-0.5">$1</mark>'
        );

      item.innerHTML = `
        <svg class="w-4 h-4 text-slate-500 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
        <div>
          <div class="text-white text-sm font-bold group-hover:text-brightcyan transition-colors">${highlighted(track.name)}</div>
          <div class="text-slate-500 text-xs mt-0.5">${highlighted(track.city)}</div>
        </div>
        <svg class="w-4 h-4 text-slate-600 ml-auto group-hover:text-brightcyan transition-colors" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"></polyline></svg>
      `;
      searchResults.appendChild(item);
    });

    if (matches.length > 8) {
      const more = document.createElement("div");
      more.className = "px-5 py-3 text-slate-500 text-xs text-center";
      more.textContent = `+${matches.length - 8} more results. Refine your search.`;
      searchResults.appendChild(more);
    }

    searchResults.classList.remove("hidden");
  });

  // ── Mobile Search ─────────────────────────────────────────────
  const mobileSearchInput = document.getElementById("mobile-search-input");
  const mobileSearchResults = document.getElementById("mobile-search-results");

  const renderMobileResults = (matches, query) => {
    mobileSearchResults.innerHTML = "";

    if (matches.length === 0) {
      mobileSearchResults.innerHTML = `<div class="px-5 py-4 text-slate-400 text-sm">No tracks found for "<span class="text-white font-bold">${mobileSearchInput.value}</span>"</div>`;
      mobileSearchResults.classList.remove("hidden");
      return;
    }

    const highlighted = (str) =>
      str.replace(
        new RegExp(`(${query})`, "gi"),
        '<mark class="bg-brightcyan/30 text-brightcyan rounded px-0.5">$1</mark>'
      );

    matches.slice(0, 8).forEach((track) => {
      const item = document.createElement("a");
      item.href = track.url;
      item.className =
        "flex items-center gap-3 px-5 py-4 hover:bg-brightcyan/10 transition-colors border-b border-white/5 last:border-0 group";
      item.innerHTML = `
        <svg class="w-4 h-4 text-slate-500 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
        <div>
          <div class="text-white text-base font-bold group-hover:text-brightcyan transition-colors">${highlighted(track.name)}</div>
          <div class="text-slate-500 text-sm mt-0.5">${highlighted(track.city)}</div>
        </div>
        <svg class="w-4 h-4 text-slate-600 ml-auto group-hover:text-brightcyan transition-colors" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"></polyline></svg>
      `;
      // Close mobile menu when a result is clicked
      item.addEventListener("click", closeMobileMenu);
      mobileSearchResults.appendChild(item);
    });

    if (matches.length > 8) {
      const more = document.createElement("div");
      more.className = "px-5 py-3 text-slate-500 text-xs text-center";
      more.textContent = `+${matches.length - 8} more results. Refine your search.`;
      mobileSearchResults.appendChild(more);
    }

    mobileSearchResults.classList.remove("hidden");
  };

  mobileSearchInput.addEventListener("input", () => {
    const query = mobileSearchInput.value.trim().toLowerCase();
    mobileSearchResults.innerHTML = "";

    if (query.length < 2) {
      mobileSearchResults.classList.add("hidden");
      return;
    }

    const matches = trackData.filter(
      (t) =>
        t.name.toLowerCase().includes(query) ||
        t.city.toLowerCase().includes(query)
    );

    renderMobileResults(matches, query);
  });

  // Clear mobile search when menu closes
  const origCloseMobileMenu = closeMobileMenu;
  // Override closeMobileMenu to also clear mobile search
  mobileToggle.addEventListener("click", () => {
    if (menuOpen) {
      mobileSearchInput.value = "";
      mobileSearchResults.classList.add("hidden");
      mobileSearchResults.innerHTML = "";
    }
  });
</script>
